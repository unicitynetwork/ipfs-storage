# IPFS Storage Service Configuration
# Copy to .env and customize

# Domain for SSL certificate and WSS announcements
DOMAIN=unicity-ipfs1.dyndns.org

# SSL Certificate paths (Let's Encrypt)
# These are passed as arguments to make commands:
#   make run SSL_CERT=/path/to/fullchain.pem SSL_KEY=/path/to/privkey.pem DOMAIN=example.com
#   make compose-up SSL_CERT=/path/to/fullchain.pem SSL_KEY=/path/to/privkey.pem DOMAIN=example.com
SSL_CERT=/etc/letsencrypt/live/example.com/fullchain.pem
SSL_KEY=/etc/letsencrypt/live/example.com/privkey.pem

# Development mode (uses self-signed certificate)
# Set to true for local development without real SSL certs
# Use: make dev
DEV_MODE=false

# IPFS Configuration
IPFS_PROFILE=server
IPFS_LOGGING=info

# Nostr Pinner Configuration
# Comma-separated list of Nostr relay URLs
NOSTR_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.nostr.band

# Nostr event kind for pin requests (NIP-78 app-specific)
PIN_KIND=30078

# Pinner log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Reconnection delay in seconds when relay disconnects
RECONNECT_DELAY=10

# Pin operation timeout in seconds
PIN_TIMEOUT=300

# IPNS staleness and chain validation configuration
# Staleness threshold (records older than this trigger async DHT refresh)
STALE_THRESHOLD_SECONDS=15

# Chain validation mode: strict | queue | log_only
# - strict: Reject records that fail chain validation (recommended for production)
# - queue: Queue failed records for later processing
# - log_only: Accept records but log violations (debugging only)
CHAIN_VALIDATION_MODE=strict

# CID fetch timeout for chain validation (seconds)
CID_FETCH_TIMEOUT=3
